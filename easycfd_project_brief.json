{
  "project_name_ja": "やさしいCFD",
  "project_name_en": "EasyCFD",
  "repo_name_suggestion": "easycfd",
  "one_line_summary": "A desktop GUI assistant that helps CFD beginners run their first OpenFOAM simulations through natural language, safe OpenFOAM command execution, and guided explanations.",

  "agent_architecture": {
    "model": "Commander / Worker",
    "commander": {
      "tool": "Claude Code",
      "responsibilities": [
        "Overall design decisions",
        "Security-critical code (safety.py, validator.py)",
        "Task decomposition and delegation to Codex",
        "Review of Codex output",
        "Debugging test failures"
      ]
    },
    "worker": {
      "tool": "Codex via MCP",
      "responsibilities": [
        "Boilerplate code generation",
        "Pydantic schema implementation",
        "Test code generation",
        "OpenFOAM template file generation",
        "Log parser implementation"
      ]
    },
    "mcp_server": {
      "location": "mcp/codex_worker/",
      "files": {
        "server.py": "MCP server entry point",
        "handlers.py": "Task handlers for Codex delegation",
        "validator.py": "Safety validation of Codex output",
        "requirements.txt": "Python dependencies"
      },
      "claude_settings": ".claude/settings.json",
      "tool_name": "codex_worker",
      "tool_parameters": {
        "task": "string - instruction for Codex",
        "context_files": "list[string] - files Codex should read",
        "constraints": "list[string] - rules Codex must follow"
      }
    },
    "delegation_rules": {
      "claude_code_only": [
        "safety.py whitelist implementation",
        "validator.py security checks",
        "Final review of all Codex output",
        "Architecture decisions"
      ],
      "codex_worker": [
        "Pydantic schemas",
        "Boilerplate code",
        "Test generation",
        "OpenFOAM templates",
        "Log parsers"
      ]
    }
  },

  "motivation": {
    "personal_context": "Motivated by the difficulty of learning CFD with OpenFOAM as a beginner.",
    "problem": "OpenFOAM is powerful but has a steep initial learning curve.",
    "goal": "Help curious students take their first step into CFD without hiding the workflow completely."
  },

  "target_users": [
    "CFD beginners",
    "Students curious about fluid simulation",
    "Self-learners trying OpenFOAM for the first time"
  ],

  "non_targets": [
    "Professional CFD engineers needing industrial accuracy",
    "Commercial CAE replacement users",
    "Arbitrary CAD-to-mesh automation users"
  ],

  "research_question_en": "Can a natural-language GUI assistant reduce the initial workflow barrier for students learning OpenFOAM-based CFD?",
  "research_question_ja": "自然言語GUIアシスタントは、OpenFOAMを用いたCFD学習における初期ワークフローの障壁を下げられるか？",

  "core_principle": "The LLM must not execute arbitrary shell commands. It should produce structured JSON plans that are validated before a safe runner executes whitelisted OpenFOAM commands. This applies to Codex output as well.",

  "mvp_scope": {
    "supported_cases": ["2D lid-driven cavity flow", "2D channel flow"],
    "supported_physics": ["incompressible flow", "laminar flow first"],
    "allowed_commands": ["blockMesh", "checkMesh", "icoFoam", "simpleFoam", "postProcess"],
    "features": [
      "template-based case generation",
      "safe OpenFOAM command runner",
      "log streaming",
      "residual parsing and plotting",
      "beginner-friendly explanations",
      "sample mode without API key",
      "OpenAI API and Ollama local LLM support"
    ],
    "out_of_scope": [
      "arbitrary CAD import",
      "snappyHexMesh automation",
      "industrial accuracy claims",
      "unrestricted shell access",
      "remote clusters"
    ]
  },

  "recommended_environment": {
    "main_development_os": "Ubuntu",
    "windows_role": "Packaging, installer testing, future Windows release builds",
    "reason": "OpenFOAM and CFD command workflows are easiest to integrate natively on Linux."
  },

  "planned_stack": {
    "frontend": "Tauri + React + TypeScript",
    "backend": "Python FastAPI",
    "cfd": "Native OpenFOAM on Ubuntu first; Docker runner later for Windows",
    "llm": ["Ollama (local, primary)", "OpenAI API (optional)", "MockProvider (sample mode)"],
    "agent": ["Claude Code (commander)", "Codex via MCP (worker)"],
    "visualization": ["Residual plots from logs", "PNG outputs", "PyVista / ParaView later"]
  },

  "repository_structure": {
    "AGENTS.md": "Instructions for Codex MCP Worker",
    "CLAUDE.md": "Instructions for Claude Code",
    "README.md": "User-facing project overview",
    "PROJECT_BRIEF.md": "Detailed project context",
    "easycfd_project_brief.json": "Machine-readable project brief",
    ".claude/settings.json": "MCP server registration for Claude Code",
    "mcp/codex_worker/server.py": "MCP server entry point",
    "mcp/codex_worker/handlers.py": "Task handlers",
    "mcp/codex_worker/validator.py": "Safety validation of Codex output",
    "apps/desktop": "Tauri + React app",
    "backend/easycfd_core": "Python backend package",
    "templates/cavity_2d": "OpenFOAM cavity template",
    "templates/channel_2d": "OpenFOAM channel template",
    "examples": "Sample prompts and cases",
    "docs": "Architecture, research plan, user study notes",
    "scripts": "Development helper scripts",
    "logs": "Agent execution logs",
    "runs": "OpenFOAM workspace"
  },

  "interfaces": {
    "OpenFOAMRunner": {
      "methods": ["run_command(case_dir: str, command: str) -> dict"],
      "implementations": ["NativeLinuxRunner", "DockerRunner (later)", "WSLRunner (later)"]
    },
    "LLMProvider": {
      "methods": ["generate_case_plan(user_prompt: str) -> dict", "explain_log(log_text: str) -> str"],
      "implementations": ["MockProvider", "OpenAIProvider", "OllamaProvider"]
    },
    "MCPCodexWorker": {
      "tool_name": "codex_worker",
      "methods": ["delegate_task(task: str, context_files: list, constraints: list) -> dict"],
      "validation": "validator.py checks all output before returning to Claude Code"
    }
  },

  "safety_constraints": {
    "allowed_commands": ["blockMesh", "checkMesh", "icoFoam", "simpleFoam", "postProcess"],
    "forbidden_patterns": ["rm", "mv", "chmod", "chown", "curl", "wget", "sudo", "python -c", ";", "&&", "|", ".."],
    "workspace_policy": "Only write inside ./runs/ or ~/.easycfd/workspaces/",
    "llm_policy": "Never trust LLM output. Always validate against schema and safety rules.",
    "codex_policy": "Codex output must pass validator.py before Claude Code reviews and accepts it."
  },

  "milestones": [
    {
      "id": 0,
      "name": "Repository Bootstrap",
      "tasks": ["README", "AGENTS.md", "CLAUDE.md", ".gitignore", ".env.example", "Python package layout", "test setup", "MCP server directory structure"]
    },
    {
      "id": 1,
      "name": "MCP Codex Worker",
      "tasks": ["server.py MCP entry point", "handlers.py task delegation", "validator.py safety checks", ".claude/settings.json MCP registration", "end-to-end delegation test"]
    },
    {
      "id": 2,
      "name": "OpenFOAM Runner",
      "tasks": ["NativeLinuxRunner", "command whitelist", "workspace path validation", "subprocess execution", "stdout/stderr capture", "safety tests"]
    },
    {
      "id": 3,
      "name": "Template-based Case Generation",
      "tasks": ["cavity_2d template", "dictionary rendering", "system/constant/0 directory generation", "parameter validation"]
    },
    {
      "id": 4,
      "name": "Solver Run and Residual Parsing",
      "tasks": ["run icoFoam/simpleFoam", "save logs", "parse residual history", "return structured data"]
    },
    {
      "id": 5,
      "name": "Minimal GUI",
      "tasks": ["Tauri + React setup", "case selection", "run button", "log panel", "residual chart"]
    },
    {
      "id": 6,
      "name": "LLM Structured Planning",
      "tasks": ["MockProvider", "OpenAIProvider", "OllamaProvider", "JSON schema validation", "provider settings UI"]
    },
    {
      "id": 7,
      "name": "Beginner Explanations",
      "tasks": ["solver explanation", "boundary condition explanation", "command explanation", "error explanation", "residual plot explanation"]
    }
  ],

  "first_agent_task": "Read PROJECT_BRIEF.md and AGENTS.md. Execute Milestone 0 and Milestone 1. Create the repository scaffold, implement mcp/codex_worker/server.py as an MCP server that delegates tasks to Codex, implement validator.py for safety checks, and register the MCP server in .claude/settings.json. Implement security-critical code yourself. Delegate boilerplate to Codex via MCP.",

  "coding_style": [
    "Simple and readable over clever abstractions",
    "Python type hints everywhere",
    "Pydantic v2 for all schemas",
    "Validate external inputs aggressively",
    "Tests required for all safety-critical behavior",
    "Keep OpenFOAM logic isolated from GUI code",
    "Never let frontend code directly execute shell commands",
    "Version LLM prompts and schemas in files"
  ],

  "testing_priorities": [
    "command whitelist",
    "workspace path validation",
    "MCP validator output checks",
    "case plan schema validation",
    "template parameter validation",
    "log parser behavior",
    "runner behavior when commands fail"
  ]
}
