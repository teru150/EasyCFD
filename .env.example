# EasyCFD Environment Configuration

# OpenFOAM Docker Image
OPENFOAM_IMAGE=openfoam/openfoam9-paraview56

# Workspace directory (default: ./runs)
EASYCFD_WORKSPACE=./runs

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# MCP Codex Worker (for development acceleration)
# OpenAI Codex/GPT-4 for code generation
OPENAI_API_KEY=your_openai_api_key_here

# LLM Provider (for EasyCFD app itself in Milestone 6-7)
# This will use LOCAL LLM (Qwen/Llama), not OpenAI
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=qwen2.5-coder

# Backend API settings
API_HOST=127.0.0.1
API_PORT=8000

# Docker settings
DOCKER_TIMEOUT=300
